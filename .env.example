# La app llama rutas RELATIVAS y el host hace de proxy al backend (mismo-origen),
# evitando el CORS del navegador (incluido PATCH).
#   - dev:    el proxy vive en vite.config.ts (usa API_PROXY_TARGET de abajo)
#   - deploy: el rewrite vive en vercel.json / public/_redirects
VITE_API_BASE_URL=/api/v1

# Origen del backend al que el proxy de DESARROLLO reenvia /api (solo local).
# El TA entrega el valor real; debe ser el host SIN /api/v1.
API_PROXY_TARGET=https://<backend-url>
